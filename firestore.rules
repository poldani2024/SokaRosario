rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Helpers base
       ========================= */
    function hasAuth() {
      return request.auth != null;
    }

    function roleDocExists() {
      return hasAuth() &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid));
    }

    function roleDoc() {
      return roleDocExists()
        ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data
        : null;
    }

    // Rol efectivo: primero claims del token, luego roles/{uid}, y por defecto Usuario
    function role() {
      return hasAuth() && request.auth.token.role is string
        ? request.auth.token.role
        : (roleDoc() != null && roleDoc().role is string
            ? roleDoc().role
            : 'Usuario');
    }

    function isAdminByEmail() {
      return hasAuth()
          && request.auth.token.email is string
          && request.auth.token.email.lower() in ['pedro.l.oldani@gmail.com', 'pedro.loldani@gmail.com'];
    }

    function isAdmin() {
      return (hasAuth() && request.auth.token.admin == true)
          || role() == 'Admin'
          || isAdminByEmail();
    }
    function isSubRegion()   { return role() == 'SubRegion'; }
    function isLiderCiudad() { return role() == 'LiderCiudad'; }
    function isLiderSector() { return role() == 'LiderSector'; }
    function isLiderHan()    { return role() == 'LiderHan'; }

    function hasAnyRole() {
      return role() in ['Admin', 'SubRegion', 'LiderCiudad', 'LiderSector', 'LiderHan', 'Usuario+', 'Usuario'];
    }

    // Compatibilidad: scope anidado nuevo + campos legacy planos
    function scopeSubregionIds() {
      return roleDoc() != null
        ? (
            roleDoc().scope != null && roleDoc().scope.subregionIds != null
              ? roleDoc().scope.subregionIds
              : (roleDoc().subregionIds != null ? roleDoc().subregionIds : [])
          )
        : [];
    }

    function scopeCityIds() {
      return roleDoc() != null
        ? (
            roleDoc().scope != null && roleDoc().scope.cityIds != null
              ? roleDoc().scope.cityIds
              : (roleDoc().cityIds != null ? roleDoc().cityIds : (roleDoc().city != null ? [roleDoc().city] : []))
          )
        : [];
    }

    function scopeSectorIds() {
      return roleDoc() != null
        ? (
            roleDoc().scope != null && roleDoc().scope.sectorIds != null
              ? roleDoc().scope.sectorIds
              : (roleDoc().sectorIds != null ? roleDoc().sectorIds : (roleDoc().sector != null ? [roleDoc().sector] : []))
          )
        : [];
    }

    function scopeHanIds() {
      return roleDoc() != null
        ? (
            roleDoc().scope != null && roleDoc().scope.hanIds != null
              ? roleDoc().scope.hanIds
              : (roleDoc().hanIds != null ? roleDoc().hanIds : [])
          )
        : [];
    }

    /* =========================
       Catálogos base
       ========================= */
    match /hanes/{hanId} {
      allow read: if hasAuth();
      allow write: if isAdmin();
    }

    match /grupos/{grupoId} {
      allow read: if hasAuth();
      allow write: if isAdmin();
    }

    match /subregiones/{id} {
      allow read: if hasAuth();
      allow write: if isAdmin();
    }

    match /ciudades/{id} {
      allow read: if hasAuth();
      allow write: if isAdmin();
    }

    match /sectores/{id} {
      allow read: if hasAuth();
      allow write: if isAdmin();
    }

    /* =========================
       Personas
       ========================= */
    match /personas/{personaId} {
      // Mantiene comportamiento actual: usuarios autenticados con rol válido pueden leer
      allow read: if hasAnyRole();

      // Escritura: Admin o dueño por uid almacenado en el documento
      allow create, update: if isAdmin()
                         || (hasAuth()
                             && request.resource.data.uid is string
                             && request.resource.data.uid == request.auth.uid);

      allow delete: if isAdmin();
    }

    /* =========================
       Datos privados por persona
       ========================= */
    match /personasPriv/{personaId} {
      allow read, write: if isAdmin() || isSubRegion() || isLiderCiudad() || isLiderSector() || isLiderHan();
    }

    /* =========================
       Visitas
       ========================= */
    match /visitas/{visitaId} {
      allow read: if hasAnyRole();
      allow write: if isAdmin() || isSubRegion() || isLiderCiudad() || isLiderSector() || isLiderHan();
    }

    /* =========================
       Roles
       ========================= */
    match /roles/{uid} {
      // Self read + Admin read/list
      allow read: if (hasAuth() && request.auth.uid == uid) || isAdmin();

      // Solo Admin crea/edita/elimina
      allow write: if isAdmin();
    }

    /* =========================
       Políticas de campos
       ========================= */
    match /fieldPolicies/{roleId} {
      // El front de seguridad (admin) necesita leer/escribir
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /* =========================
       Usuarios de acceso al sistema
       ========================= */
    match /users/{uid} {
      // Admin puede listar/leer; cada usuario puede leer su propio perfil
      allow read: if isAdmin() || (hasAuth() && request.auth.uid == uid);

      // Creación/edición: Admin o el propio usuario (alta por aceptación de invitación)
      allow create, update: if isAdmin()
                         || (hasAuth()
                             && request.auth.uid == uid
                             && request.resource.data.uid is string
                             && request.resource.data.uid == uid);

      // No hay borrado físico
      allow delete: if false;
    }

    /* =========================
       Invitaciones de usuarios
       ========================= */
    match /userInvites/{inviteId} {
      // Admin administra invitaciones
      allow create, delete: if isAdmin();

      // Admin o usuario invitado puede marcar aceptación (sin crear/editar otros campos sensibles)
      allow update: if isAdmin()
                 || (hasAuth()
                     && resource.data.email is string
                     && request.auth.token.email is string
                     && resource.data.email.lower() == request.auth.token.email.lower()
                     && request.resource.data.email == resource.data.email
                     && request.resource.data.status in ['confirmed','accepted']);

      // Lectura: Admin o usuario autenticado cuyo email coincide con la invitación
      allow read: if isAdmin()
               || (hasAuth()
                   && resource.data.email is string
                   && request.auth.token.email is string
                   && resource.data.email.lower() == request.auth.token.email.lower());
    }

    /* =========================
       Bloqueo por defecto
       ========================= */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
